{
  "name": "nekrasov",
  "version": "1.0.0",
  "description": "A modern, pluggable ProseMirror-based text editor with Markdown support",
  "main": "dist/nekrasov.cjs.js",
  "module": "dist/nekrasov.esm.js",
  "types": "dist/index.d.ts",
  "author": "Mark <strategy155@gmail.com>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nekrasov.esm.js",
      "require": "./dist/nekrasov.cjs.js"
    },
    "./style.css": "./dist/style.css"
  },
  "dependencies": {
    "dompurify": "^3.0.8",
    "markdown-it": "^14.1.0",
    "prosemirror-commands": "^1.7.0",
    "prosemirror-dropcursor": "^1.8.0",
    "prosemirror-gapcursor": "^1.3.0",
    "prosemirror-history": "^1.4.0",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.0",
    "prosemirror-menu": "^1.2.0",
    "prosemirror-model": "^1.25.0",
    "prosemirror-schema-list": "^1.5.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-tables": "^1.6.0",
    "prosemirror-transform": "^1.10.0",
    "prosemirror-view": "^1.41.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.1",
    "rollup": "^4.13.0",
    "rollup-plugin-css-only": "^4.5.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  },
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "build:watch": "rollup --config rollup.config.js --watch",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "packageManager": "yarn@4.3.1",
  "keywords": [
    "editor",
    "prosemirror",
    "markdown",
    "rich-text",
    "wysiwyg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/strategy155/nekrasov.git"
  },
  "bugs": {
    "url": "https://github.com/strategy155/nekrasov/issues"
  }
}
