# =============================================================================
# Nekrasov Editor - Git Ignore Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
# NPM/Yarn installed packages - these are restored via package.json
node_modules/

# Yarn Berry (v2+) cache and state directory
# Contains cached packages and Yarn-specific configuration
.yarn/

# -----------------------------------------------------------------------------
# Yarn Plug'n'Play (PnP) Files
# -----------------------------------------------------------------------------
# PnP runtime - generated by Yarn Berry for zero-install support
# These are machine-specific and should not be committed
.pnp.cjs
.pnp.loader.mjs

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
# Compiled distribution files - regenerated on each build via `yarn build`
# Contains: UMD, CJS, ESM bundles, TypeScript declarations, and CSS
dist/

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
# VS Code workspace settings (optional - uncomment if not sharing settings)
# .vscode/

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store

# Windows
Thumbs.db

# -----------------------------------------------------------------------------
# Debug and Logs
# -----------------------------------------------------------------------------
# NPM debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Test and Coverage
# -----------------------------------------------------------------------------
# Test coverage output
coverage/
